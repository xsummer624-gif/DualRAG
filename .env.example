# ===================== 百炼 API Key =====================
# 申请地址：https://bailian.console.aliyun.com/#/api-key
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# LLM 模型配置
LLM_DEFAULT_MODEL=qwen-flash
VL_MODEL=qwen3-vl-flash
LLM_DEFAULT_TEMPERATURE=0.1

# ===================== BGE-M3 向量模型 =====================
BGE_M3_PATH=/path/to/models/BAAI/bge-m3
BGE_DEVICE=cpu
BGE_FP16=0

# ===================== BGE Reranker 精排模型 =====================
BGE_RERANKER_LARGE=/path/to/models/BAAI/bge-reranker-large
BGE_RERANKER_DEVICE=cpu

# ===================== Milvus 向量数据库 =====================
MILVUS_URL=http://localhost:19530
CHUNKS_COLLECTION=kb_chunks
ITEM_NAME_COLLECTION=kb_item_names

# ===================== MongoDB 对话历史 =====================
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=kb002

# ===================== MinIO 对象存储 =====================
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=knowledge-base-files
MINIO_PDF_DIR=pdf_files

# ===================== Neo4j 知识图谱（可选） =====================
NEO4J_URI=bolt://localhost:7687
NEO4J_DATABASE=neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=yourpassword

# ===================== MinerU PDF 解析 =====================
# Token 申请：https://mineru.net/
MINERU_API_TOKEN=xxx
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_MODEL_SOURCE=modelscope
MODELSCOPE_CACHE=/path/to/modelscope_cache
MD_ROOT_DIR=./temp-files/

# ===================== MCP 联网搜索 =====================
MCP_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/sse

# ===================== 日志配置 =====================
LOG_CONSOLE_ENABLE=True
LOG_CONSOLE_LEVEL=INFO
LOG_FILE_ENABLE=True
LOG_FILE_LEVEL=INFO
LOG_FILE_RETENTION=7 days
